# =============================================
# BANCO DE DADOS
# =============================================
DATABASE_URL=postgresql://usebarber:SENHA_AQUI@localhost:5432/usebarber

# =============================================
# PARA DOCKER COMPOSE
# =============================================
POSTGRES_PASSWORD=SENHA_DO_BANCO_AQUI

# =============================================
# AUTENTICAÇÃO (NextAuth v5)
# Gere com: openssl rand -base64 32
# =============================================
AUTH_SECRET=gere_uma_chave_secreta_aqui
AUTH_URL=https://seudominio.com
AUTH_TRUST_HOST=true

# =============================================
# GOOGLE OAUTH
# console.cloud.google.com → Credenciais → Criar OAuth Client ID
# Authorized redirect URIs: https://seudominio.com/api/auth/callback/google
# =============================================
GOOGLE_CLIENT_ID=seu_google_client_id
GOOGLE_CLIENT_SECRET=seu_google_client_secret

# =============================================
# PAGAMENTOS — ASAAS
# Produção: https://api.asaas.com/v3
# Sandbox:  https://sandbox.asaas.com/api/v3
# =============================================
ASAAS_URL=https://api.asaas.com/v3
ASAAS_API_KEY=sua_chave_asaas_producao

# =============================================
# IA
# =============================================
GEMINI_API_KEY=sua_chave_gemini

# =============================================
# PUSH NOTIFICATIONS (Web Push / VAPID)
# Gere com: npx web-push generate-vapid-keys
# =============================================
VAPID_PUBLIC_KEY=sua_vapid_public_key
VAPID_PRIVATE_KEY=sua_vapid_private_key
